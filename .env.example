# Local testing configuration
# Copy this file to .env.local and customize for your local environment

# Local testing flags
LOCAL_TESTING=true
SKIP_DYNAMODB_CHECK=true
PROMPT_CONTEXT_STORAGE=file

# Temporal configuration for local development
TEMPORAL_SERVER_URL=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=investigate-task-queue
TEMPORAL_IDENTITY=local-worker

# ============================================================================
# Claude API Authentication Configuration
# ============================================================================
#
# RepoSwarm supports two authentication methods for Claude API access:
#
# AUTHENTICATION PRIORITY (checked in this order):
#   1. CLAUDE_CODE_OAUTH_TOKEN (highest priority - Claude Max subscription)
#   2. CLAUDE_OAUTH_TOKEN (second priority - alternative OAuth variable)
#   3. ANTHROPIC_API_KEY (fallback - standard API key)
#
# ----------------------------------------------------------------------------
# OPTION 1: OAuth Token (Claude Max Subscription) - RECOMMENDED
# ----------------------------------------------------------------------------
#
# Best for: Claude Max subscribers who want access to Max models
#
# Setup steps:
#   1. Run: mise claude-login
#      (This executes 'claude setup-token' from the official Claude CLI)
#   2. Copy the token displayed and paste below
#   3. Verify: mise claude-status
#
# Token format: sk-ant-oat01-********************************
#   - Starts with: sk-ant-oat01-
#   - Length: 50-200 characters
#   - Example: sk-ant-oat01-abcdef1234567890abcdef1234567890abcdef1234567890
#
# Benefits:
#   ✅ Access to Claude Max models (if you have a subscription)
#   ✅ Uses official Claude CLI (ToS compliant)
#   ✅ Seamless integration with Claude Code ecosystem
#
# Troubleshooting:
#   - "Invalid token format" → Ensure token starts with sk-ant-oat01-
#   - "Token expired" → Run 'mise claude-login' to generate a new token
#   - "No credentials found" → Check token is in .env.local (not .env.example)
#   - "Authentication failed" → Verify Claude Max subscription is active

# OAuth token from Claude Code (highest priority)
CLAUDE_CODE_OAUTH_TOKEN=

# OAuth token from Claude web authentication (second priority)
# Use this if your OAuth token comes from a different Claude source
CLAUDE_OAUTH_TOKEN=

# ----------------------------------------------------------------------------
# OPTION 2: API Key (Standard Anthropic API) - FALLBACK
# ----------------------------------------------------------------------------
#
# Best for: Users without Claude Max subscription or for CI/CD environments
#
# Setup steps:
#   1. Visit: https://console.anthropic.com/
#   2. Create or copy your API key
#   3. Paste below
#   4. Verify: mise claude-status
#
# Token format: sk-ant-api03-********************************
#   - Starts with: sk-ant-api03-
#   - Length: 50-200 characters
#   - Example: sk-ant-api03-zyxwvu9876543210zyxwvu9876543210zyxwvu9876543210
#
# Benefits:
#   ✅ Works with standard Anthropic API tier (pay-per-use)
#   ✅ Direct SDK integration (faster, no CLI wrapper)
#   ✅ Suitable for production and CI/CD environments
#   ✅ No Claude Max subscription required
#
# Troubleshooting:
#   - "Invalid token format" → Ensure token starts with sk-ant-api03-
#   - "Token expired" → Regenerate in Anthropic Console
#   - "Rate limit exceeded" → Check usage limits in Anthropic dashboard
#   - "Insufficient credits" → Add credits in Anthropic Console

# API key from Anthropic Console (fallback)
ANTHROPIC_API_KEY=

# ----------------------------------------------------------------------------
# WHEN TO USE WHICH METHOD?
# ----------------------------------------------------------------------------
#
# Use CLAUDE_CODE_OAUTH_TOKEN if:
#   ✅ You have a Claude Max subscription
#   ✅ You want to use Claude Max models
#   ✅ You're developing locally with Claude Code
#   ✅ You need web authentication integration
#
# Use ANTHROPIC_API_KEY if:
#   ✅ You don't have Claude Max subscription
#   ✅ You're running in CI/CD or production environments
#   ✅ You prefer direct SDK integration (no CLI wrapper)
#   ✅ You have a separate Anthropic API subscription
#
# NOTE: If both are set, CLAUDE_CODE_OAUTH_TOKEN takes priority.
#       To verify which method is active, run: mise claude-status
#
# ============================================================================

# Optional: Override repository settings for testing
# GitHub tokens: classic (ghp_*) or fine-grained (ghu_* / github_pat_*)
# Fine-grained tokens require repo access + Contents read/write permission.
# Examples: ghp_********************************, ghu_********************************, github_pat_********************************
# If you see permission errors (403/404), verify repo access and Contents permission for the token.
# GITHUB_TOKEN=your-github-token-here
GITHUB_TOKEN=

# Architecture Hub Configuration (for local testing)
ARCH_HUB_REPO_NAME=repo-swarm-sample-results-hub
ARCH_HUB_BASE_URL=https://github.com/example
# empty means root
ARCH_HUB_FILES_DIR=

# Repository Configuration (for local testing)
DEFAULT_ORG_NAME=royosherove
DEFAULT_REPO_URL=https://github.com/sindresorhus/is

# Git Configuration (for local testing)
GIT_USER_NAME="Architecture Bot"
GIT_USER_EMAIL=archbot@example.com

# Optional: Local DynamoDB settings (if testing with local DynamoDB)
# AWS_ACCESS_KEY_ID=local
# AWS_SECRET_ACCESS_KEY=local
# AWS_REGION=us-east-1
# DYNAMODB_ENDPOINT_URL=http://localhost:8000

# Optional: Debug settings
# LOG_LEVEL=DEBUG
# PYTHONUNBUFFERED=1
